{
  "name": "listicle-app",
  "version": "1.0.0",
  "description": "A listicle web app displaying VPSFL calendar events",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "scrape": "node server/scripts/scraper.js",
    "db:sync": "node server/config/databasequery.js",
    "dev": "nodemon server/server.js",
    "compose:up": "powershell -ExecutionPolicy Bypass -File ./scripts/compose.ps1 up",
    "compose:scrape": "powershell -ExecutionPolicy Bypass -File ./scripts/compose.ps1 scrape",
    "compose:status": "powershell -ExecutionPolicy Bypass -File ./scripts/compose.ps1 status",
    "compose:down": "powershell -ExecutionPolicy Bypass -File ./scripts/compose.ps1 down",
    "compose:logs": "powershell -ExecutionPolicy Bypass -File ./scripts/compose.ps1 logs"
  },
  "keywords": ["listicle", "events", "express"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cheerio": "^1.0.0-rc.12",
    "axios": "^1.6.2",
    "dotenv": "^16.4.5",
    "pg": "^8.13.1",
    "puppeteer": "^21.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
